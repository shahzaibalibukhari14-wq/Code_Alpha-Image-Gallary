<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Image Gallery — Light & Dark</title>
    <style>
        *,
        *::before,
        *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            background: #0a0a12;
            color: #f0f0f5;
            min-height: 100vh;
            padding: 2rem 1.5rem 4rem;
            background-image: radial-gradient(circle at 10% 20%, rgba(108, 92, 231, 0.08) 0%, transparent 40%),
                              radial-gradient(circle at 90% 80%, rgba(9, 132, 227, 0.06) 0%, transparent 45%);
        }

        ::-webkit-scrollbar {
            width: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #14141f;
        }
        ::-webkit-scrollbar-thumb {
            background: linear-gradient(135deg, #a29bfe, #6c5ce7, #0984e3);
            border-radius: 10px;
        }

        .gallery-header {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 1.2rem;
            margin-bottom: 3rem;
            text-align: center;
        }

        .gallery-header h1 {
            font-size: 2.8rem;
            font-weight: 700;
            letter-spacing: -0.5px;
            background: linear-gradient(135deg, #f0f0f5 0%, #a29bfe 40%, #6c5ce7 70%, #0984e3 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            text-shadow: 0 0 40px rgba(108, 92, 231, 0.15);
        }

        .gallery-header p {
            color: #9a9ab5;
            font-size: 1.05rem;
            margin-top: -0.4rem;
            letter-spacing: 0.3px;
        }

        .filter-bar {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 0.6rem;
            margin-top: 0.2rem;
            background: rgba(255, 255, 255, 0.03);
            padding: 0.4rem 0.6rem;
            border-radius: 60px;
            backdrop-filter: blur(6px);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .filter-btn {
            padding: 0.6rem 1.6rem;
            border: none;
            border-radius: 50px;
            background: transparent;
            color: #b0b0cc;
            font-size: 0.9rem;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
            letter-spacing: 0.4px;
            position: relative;
        }

        .filter-btn::after {
            content: '';
            position: absolute;
            inset: 0;
            border-radius: 50px;
            padding: 1px;
            background: linear-gradient(135deg, rgba(162, 155, 254, 0.2), rgba(9, 132, 227, 0.1));
            -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
            -webkit-mask-composite: xor;
            mask-composite: exclude;
            opacity: 0;
            transition: opacity 0.4s ease;
        }

        .filter-btn:hover {
            color: #fff;
            background: rgba(255, 255, 255, 0.06);
            transform: translateY(-2px);
            box-shadow: 0 6px 24px rgba(108, 92, 231, 0.1);
        }

        .filter-btn.active {
            background: linear-gradient(135deg, rgba(108, 92, 231, 0.25), rgba(9, 132, 227, 0.2));
            color: #fff;
            box-shadow: 0 4px 24px rgba(108, 92, 231, 0.25), inset 0 1px 0 rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(4px);
        }

        .filter-btn.active::after {
            opacity: 1;
        }

        .gallery-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1.4rem;
            max-width: 1440px;
            margin: 0 auto;
        }

        .gallery-item {
            position: relative;
            border-radius: 20px;
            overflow: hidden;
            cursor: pointer;
            aspect-ratio: 4 / 3;
            background: #14141f;
            transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1),
                box-shadow 0.5s ease;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5), inset 0 0 0 1px rgba(255, 255, 255, 0.03);
            will-change: transform;
        }

        .gallery-item:hover {
            transform: scale(1.04) translateY(-6px);
            box-shadow: 0 16px 56px rgba(108, 92, 231, 0.3), 0 0 0 1px rgba(162, 155, 254, 0.15);
            z-index: 2;
        }

        .gallery-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            transition: transform 0.7s cubic-bezier(0.34, 1.56, 0.64, 1),
                filter 0.6s ease;
            filter: saturate(0.9) brightness(0.95);
        }

        .gallery-item:hover img {
            transform: scale(1.12);
            filter: saturate(1.1) brightness(1.05);
        }

        .gallery-item .overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(0deg,
                    rgba(0, 0, 0, 0.8) 0%,
                    rgba(0, 0, 0, 0.2) 50%,
                    transparent 100%);
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            padding: 1.4rem 1.4rem 1.6rem;
            opacity: 0;
            transition: opacity 0.4s ease;
        }

        .gallery-item:hover .overlay {
            opacity: 1;
        }

        .gallery-item .overlay .title {
            font-size: 1.1rem;
            font-weight: 600;
            color: #fff;
            transform: translateY(12px);
            transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1),
                opacity 0.4s ease;
            opacity: 0;
            text-shadow: 0 2px 12px rgba(0, 0, 0, 0.6);
        }

        .gallery-item:hover .overlay .title {
            transform: translateY(0);
            opacity: 1;
        }

        .gallery-item .overlay .category-tag {
            display: inline-block;
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            color: rgba(255, 255, 255, 0.9);
            background: rgba(108, 92, 231, 0.35);
            backdrop-filter: blur(8px);
            padding: 0.2rem 1rem;
            border-radius: 50px;
            align-self: flex-start;
            margin-bottom: 0.5rem;
            transform: translateY(8px);
            transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1),
                opacity 0.4s ease;
            opacity: 0;
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        .gallery-item:hover .overlay .category-tag {
            transform: translateY(0);
            opacity: 1;
        }

        .gallery-item::before {
            content: '';
            position: absolute;
            inset: -1px;
            border-radius: 20px;
            padding: 1px;
            background: linear-gradient(135deg, rgba(162, 155, 254, 0.2), rgba(9, 132, 227, 0.05));
            -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
            -webkit-mask-composite: xor;
            mask-composite: exclude;
            pointer-events: none;
            opacity: 0;
            transition: opacity 0.5s ease;
        }

        .gallery-item:hover::before {
            opacity: 1;
        }

        .gallery-item {
            opacity: 0;
            animation: fadeUp 0.7s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
        }

        .gallery-item:nth-child(1) { animation-delay: 0.02s; }
        .gallery-item:nth-child(2) { animation-delay: 0.05s; }
        .gallery-item:nth-child(3) { animation-delay: 0.08s; }
        .gallery-item:nth-child(4) { animation-delay: 0.11s; }
        .gallery-item:nth-child(5) { animation-delay: 0.14s; }
        .gallery-item:nth-child(6) { animation-delay: 0.17s; }
        .gallery-item:nth-child(7) { animation-delay: 0.20s; }
        .gallery-item:nth-child(8) { animation-delay: 0.23s; }
        .gallery-item:nth-child(9) { animation-delay: 0.26s; }
        .gallery-item:nth-child(10) { animation-delay: 0.29s; }
        .gallery-item:nth-child(11) { animation-delay: 0.32s; }
        .gallery-item:nth-child(12) { animation-delay: 0.35s; }
        .gallery-item:nth-child(13) { animation-delay: 0.38s; }
        .gallery-item:nth-child(14) { animation-delay: 0.41s; }
        .gallery-item:nth-child(15) { animation-delay: 0.44s; }
        .gallery-item:nth-child(16) { animation-delay: 0.47s; }

        @keyframes fadeUp {
            0% {
                opacity: 0;
                transform: translateY(30px) scale(0.96);
            }
            100% {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        .lightbox {
            position: fixed;
            inset: 0;
            z-index: 1000;
            background: rgba(8, 8, 16, 0.92);
            backdrop-filter: blur(28px);
            -webkit-backdrop-filter: blur(28px);
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            visibility: hidden;
            transition: opacity 0.45s ease, visibility 0.45s ease;
            padding: 1.5rem;
        }

        .lightbox.open {
            opacity: 1;
            visibility: visible;
        }

        .lightbox-content {
            position: relative;
            max-width: 1200px;
            width: 100%;
            max-height: 90vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            transform: scale(0.92) translateY(20px);
            transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .lightbox.open .lightbox-content {
            transform: scale(1) translateY(0);
        }

        .lightbox-content .image-wrapper {
            position: relative;
            width: 100%;
            height: auto;
            max-height: 80vh;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 24px 80px rgba(0, 0, 0, 0.9), 0 0 0 1px rgba(255, 255, 255, 0.04);
            background: #0b0b12;
        }

        .lightbox-content .image-wrapper img {
            width: 100%;
            height: auto;
            max-height: 80vh;
            object-fit: contain;
            display: block;
            border-radius: 24px;
            transition: opacity 0.4s ease;
        }

        .lightbox-content .image-wrapper img.loading {
            opacity: 0.4;
        }

        .lightbox-info {
            display: flex;
            justify-content: space-between;
            align-items: center;
            width: 100%;
            padding: 1.2rem 0.5rem 0;
            color: #c8c8e0;
            font-size: 0.95rem;
        }

        .lightbox-info .lb-title {
            font-weight: 500;
            color: #fff;
            text-shadow: 0 2px 12px rgba(0, 0, 0, 0.5);
        }

        .lightbox-info .lb-counter {
            font-size: 0.85rem;
            color: #8888aa;
            background: rgba(255, 255, 255, 0.06);
            padding: 0.25rem 1.2rem;
            border-radius: 50px;
            border: 1px solid rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(4px);
        }

        .lb-close {
            position: absolute;
            top: 1.2rem;
            right: 1.2rem;
            z-index: 10;
            width: 48px;
            height: 48px;
            border: none;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.06);
            backdrop-filter: blur(8px);
            color: #fff;
            font-size: 1.6rem;
            cursor: pointer;
            transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px solid rgba(255, 255, 255, 0.06);
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
        }

        .lb-close:hover {
            background: rgba(255, 70, 70, 0.25);
            transform: rotate(90deg) scale(1.08);
            border-color: rgba(255, 70, 70, 0.2);
        }

        .lb-nav {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            z-index: 10;
            width: 56px;
            height: 56px;
            border: none;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(8px);
            color: #fff;
            font-size: 1.8rem;
            cursor: pointer;
            transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px solid rgba(255, 255, 255, 0.05);
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.25);
        }

        .lb-nav:hover {
            background: rgba(255, 255, 255, 0.12);
            transform: translateY(-50%) scale(1.08);
            box-shadow: 0 8px 36px rgba(108, 92, 231, 0.25);
            border-color: rgba(162, 155, 254, 0.15);
        }

        .lb-nav.prev {
            left: 0.5rem;
        }
        .lb-nav.next {
            right: 0.5rem;
        }

        .lb-nav svg {
            width: 26px;
            height: 26px;
            fill: currentColor;
        }

        .no-results {
            grid-column: 1 / -1;
            text-align: center;
            padding: 4rem 2rem;
            color: #666688;
            font-size: 1.1rem;
            background: rgba(255, 255, 255, 0.02);
            border-radius: 24px;
            border: 1px solid rgba(255, 255, 255, 0.04);
        }
        .no-results span {
            display: block;
            font-size: 3.2rem;
            margin-bottom: 1rem;
        }

        @media (max-width: 1100px) {
            .gallery-grid {
                grid-template-columns: repeat(3, 1fr);
                gap: 1rem;
            }
        }

        @media (max-width: 768px) {
            body {
                padding: 1.2rem 1rem 3rem;
            }

            .gallery-header h1 {
                font-size: 2.2rem;
            }
            .gallery-header p {
                font-size: 0.95rem;
            }

            .filter-bar {
                padding: 0.3rem 0.4rem;
                border-radius: 40px;
                gap: 0.3rem;
            }

            .filter-btn {
                padding: 0.4rem 1.2rem;
                font-size: 0.8rem;
            }

            .gallery-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 0.8rem;
            }

            .gallery-item .overlay .title {
                font-size: 0.95rem;
            }

            .lightbox {
                padding: 0.8rem;
            }
            .lb-nav {
                width: 42px;
                height: 42px;
                font-size: 1.4rem;
            }
            .lb-nav svg {
                width: 20px;
                height: 20px;
            }
            .lb-nav.prev {
                left: 0.2rem;
            }
            .lb-nav.next {
                right: 0.2rem;
            }
            .lb-close {
                top: 0.8rem;
                right: 0.8rem;
                width: 40px;
                height: 40px;
                font-size: 1.2rem;
            }
            .lightbox-info {
                font-size: 0.85rem;
                padding: 0.6rem 0.2rem 0;
            }
            .lightbox-info .lb-counter {
                font-size: 0.75rem;
                padding: 0.15rem 0.8rem;
            }
            .lightbox-content .image-wrapper {
                border-radius: 16px;
            }
        }

        @media (max-width: 480px) {
            .gallery-grid {
                grid-template-columns: 1fr 1fr;
                gap: 0.6rem;
            }

            .gallery-header h1 {
                font-size: 1.8rem;
            }

            .filter-btn {
                padding: 0.3rem 1rem;
                font-size: 0.7rem;
            }

            .gallery-item .overlay .title {
                font-size: 0.8rem;
            }
            .gallery-item .overlay .category-tag {
                font-size: 0.55rem;
                padding: 0.1rem 0.7rem;
            }
            .gallery-item .overlay {
                padding: 0.8rem;
            }

            .lb-nav {
                width: 36px;
                height: 36px;
                font-size: 1rem;
            }
            .lb-nav svg {
                width: 18px;
                height: 18px;
            }
            .lightbox-content .image-wrapper {
                border-radius: 12px;
            }
        }

        @media (max-width: 380px) {
            .gallery-grid {
                grid-template-columns: 1fr;
                gap: 0.8rem;
            }
        }

        .gallery-item .shimmer {
            position: absolute;
            inset: 0;
            background: linear-gradient(90deg,
                    transparent 0%,
                    rgba(255, 255, 255, 0.04) 50%,
                    transparent 100%);
            background-size: 200% 100%;
            animation: shimmer 2s infinite;
            pointer-events: none;
        }

        @keyframes shimmer {
            0% { background-position: -200% 0; }
            100% { background-position: 200% 0; }
        }

        .filter-btn:focus-visible,
        .lb-nav:focus-visible,
        .lb-close:focus-visible {
            outline: 2px solid #a29bfe;
            outline-offset: 2px;
        }

        .gallery-item:focus-visible {
            outline: 3px solid #a29bfe;
            outline-offset: 2px;
        }

        html {
            scroll-behavior: smooth;
        }
    </style>
</head>
<body>

    <header class="gallery-header">
        <h1>✨ Image Gallery</h1>
        <p>Hover to preview · Click to immerse · Light &amp; Dark harmony</p>
        <div class="filter-bar" id="filterBar" role="tablist">
            <button class="filter-btn active" data-filter="all" role="tab" aria-selected="true">All</button>
            <button class="filter-btn" data-filter="nature" role="tab" aria-selected="false">🌿 Nature</button>
            <button class="filter-btn" data-filter="city" role="tab" aria-selected="false">🏙️ City</button>
            <button class="filter-btn" data-filter="animals" role="tab" aria-selected="false">🐾 Animals</button>
            <button class="filter-btn" data-filter="food" role="tab" aria-selected="false">🍽️ Food</button>
        </div>
    </header>

    <main>
        <div class="gallery-grid" id="galleryGrid"></div>
    </main>

    <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Image lightbox">
        <div class="lightbox-content">
            <button class="lb-close" id="lbClose" aria-label="Close lightbox">✕</button>
            <button class="lb-nav prev" id="lbPrev" aria-label="Previous image">
                <svg viewBox="0 0 24 24"><path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
            </button>
            <button class="lb-nav next" id="lbNext" aria-label="Next image">
                <svg viewBox="0 0 24 24"><path d="M8.59 16.59L10 18l6-6-6-6-1.41 1.41L13.17 12z"/></svg>
            </button>

            <div class="image-wrapper">
                <img src="" alt="" id="lbImage" class="loading" />
                <div class="shimmer"></div>
            </div>

            <div class="lightbox-info">
                <span class="lb-title" id="lbTitle">Untitled</span>
                <span class="lb-counter" id="lbCounter">1 / 16</span>
            </div>
        </div>
    </div>

    <script>
        const imageData = [
            { id: 1, seed: 'alpine', title: 'Alpine Lake', category: 'nature' },
            { id: 2, seed: 'cityscape', title: 'City Lights', category: 'city' },
            { id: 3, seed: 'forest', title: 'Misty Forest', category: 'nature' },
            { id: 4, seed: 'skyline', title: 'Skyline View', category: 'city' },
            { id: 5, seed: 'ocean', title: 'Ocean Sunset', category: 'nature' },
            { id: 6, seed: 'sunset', title: 'Golden Hour', category: 'nature' },
            { id: 7, seed: 'eagle', title: 'Bald Eagle', category: 'animals' },
            { id: 8, seed: 'waterfall', title: 'Mountain Falls', category: 'nature' },
            { id: 9, seed: 'fox', title: 'Red Fox', category: 'animals' },
            { id: 10, seed: 'bridge', title: 'City Bridge', category: 'city' },
            { id: 11, seed: 'deer', title: 'Deer in Forest', category: 'animals' },
            { id: 12, seed: 'architecture', title: 'Modern Architecture', category: 'city' },
            { id: 13, seed: 'pasta', title: 'Fresh Pasta', category: 'food' },
            { id: 14, seed: 'sushi', title: 'Sushi Platter', category: 'food' },
            { id: 15, seed: 'cake', title: 'Chocolate Cake', category: 'food' },
            { id: 16, seed: 'coffee', title: 'Morning Coffee', category: 'food' },
        ];

        const categoryLabels = {
            nature: 'Nature',
            city: 'City',
            animals: 'Animals',
            food: 'Food',
        };

        let currentFilter = 'all';
        let currentImages = [...imageData];
        let lightboxIndex = 0;
        let lightboxImages = [];

        const grid = document.getElementById('galleryGrid');
        const filterBar = document.getElementById('filterBar');
        const lightbox = document.getElementById('lightbox');
        const lbImage = document.getElementById('lbImage');
        const lbTitle = document.getElementById('lbTitle');
        const lbCounter = document.getElementById('lbCounter');
        const lbClose = document.getElementById('lbClose');
        const lbPrev = document.getElementById('lbPrev');
        const lbNext = document.getElementById('lbNext');

        function getImageUrl(seed, width, height) {
            return `https://picsum.photos/seed/${seed}/${width}/${height}`;
        }

        function getCategoryLabel(cat) {
            return categoryLabels[cat] || cat;
        }

        function renderGallery(images) {
            if (!images || images.length === 0) {
                grid.innerHTML = `
                    <div class="no-results">
                        <span>🔍</span>
                        No images found for this category.
                    </div>
                `;
                return;
            }

            let html = '';
            images.forEach((img, idx) => {
                const src = getImageUrl(img.seed, 600, 400);
                const catLabel = getCategoryLabel(img.category);
                html += `
                    <div class="gallery-item" data-id="${img.id}" data-category="${img.category}" tabindex="0" role="button" aria-label="Open ${img.title}">
                        <img src="${src}" alt="${img.title}" loading="lazy" />
                        <div class="shimmer"></div>
                        <div class="overlay">
                            <span class="category-tag">${catLabel}</span>
                            <span class="title">${img.title}</span>
                        </div>
                    </div>
                `;
            });

            grid.innerHTML = html;

            document.querySelectorAll('.gallery-item').forEach((el) => {
                el.addEventListener('click', () => {
                    const id = parseInt(el.dataset.id, 10);
                    openLightbox(id);
                });
                el.addEventListener('keydown', (e) => {
                    if (e.key === 'Enter' || e.key === ' ') {
                        e.preventDefault();
                        const id = parseInt(el.dataset.id, 10);
                        openLightbox(id);
                    }
                });
            });
        }

        function setFilter(filter) {
            currentFilter = filter;

            document.querySelectorAll('.filter-btn').forEach((btn) => {
                const f = btn.dataset.filter;
                const isActive = f === filter;
                btn.classList.toggle('active', isActive);
                btn.setAttribute('aria-selected', isActive ? 'true' : 'false');
            });

            if (filter === 'all') {
                currentImages = [...imageData];
            } else {
                currentImages = imageData.filter((img) => img.category === filter);
            }

            renderGallery(currentImages);
        }

        function openLightbox(id) {
            const visibleItems = document.querySelectorAll('.gallery-item');
            const visibleIds = Array.from(visibleItems).map((el) => parseInt(el.dataset.id, 10));

            lightboxImages = visibleIds
                .map((i) => imageData.find((img) => img.id === i))
                .filter(Boolean);

            const index = lightboxImages.findIndex((img) => img.id === id);
            if (index === -1) return;

            lightboxIndex = index;
            showLightboxImage();
            lightbox.classList.add('open');
            document.body.style.overflow = 'hidden';

            setTimeout(() => lbClose.focus(), 100);
        }

        function closeLightbox() {
            lightbox.classList.remove('open');
            document.body.style.overflow = '';
            const focused = document.activeElement;
            if (focused && focused.closest('.lightbox')) {
                const items = document.querySelectorAll('.gallery-item');
                if (items.length > 0) items[0].focus();
            }
        }

        function showLightboxImage() {
            const img = lightboxImages[lightboxIndex];
            if (!img) return;

            const src = getImageUrl(img.seed, 1200, 800);
            lbImage.src = src;
            lbImage.alt = img.title;
            lbImage.classList.add('loading');
            lbTitle.textContent = img.title;
            lbCounter.textContent = `${lightboxIndex + 1} / ${lightboxImages.length}`;

            lbImage.onload = () => {
                lbImage.classList.remove('loading');
            };
            lbImage.onerror = () => {
                lbImage.classList.remove('loading');
                lbImage.src = '';
                lbImage.alt = 'Image failed to load';
            };
        }

        function prevImage() {
            if (lightboxImages.length === 0) return;
            lightboxIndex = (lightboxIndex - 1 + lightboxImages.length) % lightboxImages.length;
            showLightboxImage();
        }

        function nextImage() {
            if (lightboxImages.length === 0) return;
            lightboxIndex = (lightboxIndex + 1) % lightboxImages.length;
            showLightboxImage();
        }

        document.addEventListener('keydown', (e) => {
            if (!lightbox.classList.contains('open')) return;

            switch (e.key) {
                case 'Escape':
                    closeLightbox();
                    break;
                case 'ArrowLeft':
                    e.preventDefault();
                    prevImage();
                    break;
                case 'ArrowRight':
                    e.preventDefault();
                    nextImage();
                    break;
            }
        });

        filterBar.addEventListener('click', (e) => {
            const btn = e.target.closest('.filter-btn');
            if (!btn) return;
            if (btn.dataset.filter === currentFilter) return;
            setFilter(btn.dataset.filter);
        });

        lbClose.addEventListener('click', closeLightbox);
        lbPrev.addEventListener('click', prevImage);
        lbNext.addEventListener('click', nextImage);

        lightbox.addEventListener('click', (e) => {
            if (e.target === lightbox) closeLightbox();
        });

        renderGallery(imageData);

        function preloadAdjacent() {
            const observer = new MutationObserver(() => {
                if (lightbox.classList.contains('open')) {
                    const prevIdx = (lightboxIndex - 1 + lightboxImages.length) % lightboxImages.length;
                    const nextIdx = (lightboxIndex + 1) % lightboxImages.length;
                    [prevIdx, nextIdx].forEach((idx) => {
                        const img = lightboxImages[idx];
                        if (img) {
                            const link = document.createElement('link');
                            link.rel = 'preload';
                            link.as = 'image';
                            link.href = getImageUrl(img.seed, 1200, 800);
                            document.head.appendChild(link);
                        }
                    });
                }
            });
            observer.observe(lightbox, { attributes: true, attributeFilter: ['class'] });
        }
        preloadAdjacent();

        console.log('✨ Gallery ready — Light & Dark harmony');
        console.log(`📷 ${imageData.length} images across ${Object.keys(categoryLabels).length} categories.`);
    </script>

</body>
